spring.application.name=ApiGateway
server.port=8080

eureka.client.service-url.defaultZone=http://localhost:8761/eureka

spring.cloud.gateway.routes[0].id=veterinaria
spring.cloud.gateway.routes[0].uri=lb://veterinaria-service
spring.cloud.gateway.routes[0].predicates[0]=Path=/veterinaria/**

spring.cloud.gateway.routes[1].id=responsables
spring.cloud.gateway.routes[1].uri=lb://responsables-service
spring.cloud.gateway.routes[1].predicates[0]=Path=/responsables/**

spring.cloud.gateway.routes[2].id=mascotas
spring.cloud.gateway.routes[2].uri=lb://mascotas-service
spring.cloud.gateway.routes[2].predicates[0]=Path=/mascotas/**

spring.cloud.gateway.routes[3].id=clientes
spring.cloud.gateway.routes[3].uri=lb://clientes-service
spring.cloud.gateway.routes[3].predicates[0]=Path=/clientes/**