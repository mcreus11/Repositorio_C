package com.mx.Responsables.Feign;

import org.springframework.cloud.openfeign.FeignClient;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;

import com.mx.Responsables.Entidad.Veterinaria;

@FeignClient(name = "veterinaria") // Nombre registrado en Eureka
public interface VeterinariaClient {
    @GetMapping("/veterinaria/{id}")
    Veterinaria obtenerPorId(@PathVariable("id") Long id);
}